# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Discord Channel ID (default channel for messages)
DISCORD_CHANNEL_ID=

# Discord Client/Application ID (for slash command registration)
# Find it in Discord Developer Portal → Application → General Information
DISCORD_CLIENT_ID=

# Discord Guild ID (optional — restricts commands to one server, instant updates)
# Omit for global registration (takes up to 1 hour to propagate)
DISCORD_GUILD_ID=

# Optional: Discord Webhook URL (for hooks module, zero-infrastructure option)
# If set, hooks use this instead of Bot API. Create via Discord channel settings.
DISCORD_WEBHOOK_URL=

# Optional: Filter which hook events are forwarded to Discord
# Comma-separated list. Default: all events.
# Values: Stop, SessionEnd, Notification, PreToolUse, PostToolUse, SubagentStop
DISCORD_HOOK_EVENTS=
